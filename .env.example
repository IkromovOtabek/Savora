# MongoDB klaster (master va barcha tenant bazalari shu klasterda)
MONGO_URI=mongodb://127.0.0.1:27017
MASTER_DB_NAME=savdopro_master

# Sessiya (kamida 32 belgi)
SESSION_SECRET=savdopro-super-secret-change-this-32chars

# Asosiy domen
# Lokal dev: lvh.me (dokon1.lvh.me:3000 → localhost ga ishora qiladi)
# Production: savora.uz
ROOT_DOMAIN=lvh.me
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_USE_PATH_ROUTING=true

# ── PRODUCTION (savora.uz) ──────────────────────────────────
# Bu qiymatlarni serverda o'rnating (yoki .env.production faylida):
#   ROOT_DOMAIN=savora.uz
#   NEXT_PUBLIC_ROOT_DOMAIN=savora.uz
#   NODE_ENV=production
#   NEXT_PUBLIC_APP_URL=https://savora.uz
#   NEXT_PUBLIC_USE_PATH_ROUTING=true   # bitta domen + path (savora.uz/super, /t/<slug>)

# Cron (obuna muddati)
CRON_SECRET=your-cron-secret-here

# Telegram (ixtiyoriy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bot foydalanuvchi nomi (@ siz) — Telegram ulash havolasi va parol tiklash uchun
TELEGRAM_BOT_USERNAME=
# Webhook'ni o'rnatish:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://api.savora.uz/api/telegram/webhook"

# Cloudflare R2 — fayl/rasm saqlash (ixtiyoriy; bo'sh bo'lsa lokal public/uploads ishlatiladi)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=savora-uploads
R2_PUBLIC_URL=https://cdn.savora.uz

# Zaxira (backup) — mongodump topilgan bo'lishi kerak. Saqlash joyi (ixtiyoriy)
BACKUP_DIR=./backups
